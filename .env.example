# ================================================
# FSALYDA – Variables d'environnement
# Copiez ce fichier en .env.local et renseignez les valeurs
# ================================================

# --- Authentification NextAuth ---
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# --- Base de données MongoDB ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/fsalyda

# --- Service d'email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- AWS S3 – Stockage fichiers (photos, audio, pièces jointes) ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-west-3
# Nom du bucket S3 (utilisé partout dans le projet)
AWS_S3_BUCKET=fsalyda-stockage-2025

# NOTE: AWS_BUCKET_NAME est un alias accepté pour compatibilité
# mais AWS_S3_BUCKET est la variable canonique à utiliser
